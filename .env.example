# Chiave API Google Gemini — ottenibile da https://ai.google.dev/
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_GEMINI_MODEL_NAME=gemini-2.5-flash

# Database PostgreSQL (Neon)
# DATABASE_URL: URL pooled — usata dal client Prisma a runtime (hostname con -pooler)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/bloom_buddy?sslmode=require"
# DIRECT_URL: URL diretta — usata da Prisma CLI per le migrazioni (bypassa il pooler)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/bloom_buddy?sslmode=require"

# Sessione utente (iron-session) — stringa segreta di almeno 32 caratteri
SESSION_SECRET="cambia-questa-stringa-con-almeno-32-caratteri-casuali"
