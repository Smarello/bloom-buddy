// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// In Prisma 7 la stringa di connessione è configurata in prisma.config.ts
// tramite `datasource.url: process.env["DATABASE_URL"]`.
// Imposta DATABASE_URL nel file .env (vedi .env.example per il formato).
datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  analisi      Analisi[]
  collezioni   Collezione[]
}

model Collezione {
  id              String    @id @default(cuid())
  nome            String
  nomeScientifico String?
  utenteId        String
  createdAt       DateTime  @default(now())
  utente          User      @relation(fields: [utenteId], references: [id])
  analisi         Analisi[]

  @@index([utenteId])
}

model Analisi {
  id            String       @id @default(cuid())
  urlFoto       String
  datiAnalisi   Json
  hashFoto      String
  utenteId      String
  collezioneId  String?
  createdAt     DateTime     @default(now())
  utente        User         @relation(fields: [utenteId], references: [id])
  collezione    Collezione?  @relation(fields: [collezioneId], references: [id])

  @@unique([utenteId, hashFoto])
}
